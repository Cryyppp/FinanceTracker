<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="FinanceTracker.MainWindow"
        Title="MainWindow"
        WindowState="Maximized"
        Background="#F4F7F6">

    <Grid>
        <!-- Background shapes (kept in a Canvas so positioning stays the same) -->
        <Canvas Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth}"
                Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualHeight}"
                IsHitTestVisible="False">
            <Ellipse Fill="#FF62F5C4" Width="1542" Height="1164" Canvas.Left="-362" Canvas.Top="-184"/>
            <Ellipse Fill="#FF62F5C4" Width="1536" Height="1318" Canvas.Left="720" Canvas.Top="128"/>

            <Ellipse Fill="#FFE4E6E5" Width="1432" Height="1362" Canvas.Left="-332" Canvas.Top="-82"/>
            <Ellipse Fill="#FFE4E6E5" Width="900" Height="900" Canvas.Left="776" Canvas.Top="310"/>

            <Ellipse Fill="#FFF4F7F6" Width="1242" Height="1388" Canvas.Left="-362" Canvas.Top="260"/>
            <Ellipse Fill="#FFF4F7F6" Width="900" Height="900" Canvas.Left="600" Canvas.Top="546"/>
        </Canvas>

        <!-- Overlay content: login and page grids. They stretch and are positioned using alignment rather than fixed sizes. -->
        <Grid x:Name="_loginGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- CONTENUTO -->
            <Grid Background="#00000000">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- TESTO -->
                <StackPanel Grid.Column="0" Margin="150,180,50,0" MaxWidth="750">
                    <TextBlock Text="Welcome!"
                            FontSize="140"
                            FontWeight="Bold"
                            Foreground="#2ECC71"/>
                    <TextBlock Text="To start please complete the form"
                            FontSize="65"
                            Foreground="#23A95C"
                            TextWrapping="Wrap"/>
                </StackPanel>

                <!-- CARD LOGIN -->
                <Border Grid.Column="1" Width="550"
                        Padding="50"
                        Background="White"
                        CornerRadius="25"
                        VerticalAlignment="Center"
                        Margin="0,0,150,0">

                    <!-- Ombra semplice -->
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25"
                                ShadowDepth="5"
                                Opacity="0.2"/>
                    </Border.Effect>

                    <StackPanel>

                        <TextBlock Text="Login"
                                FontSize="50"
                                FontWeight="Bold"
                                Margin="0,0,0,40"
                                Foreground="#333"/>

                        <!-- Nome -->
                        <TextBlock Text="Nome"
                                FontSize="22"
                                Foreground="#666"/>

                        <TextBox x:Name="_txtboxname" Height="65"
                                Margin="0,8,0,25"
                                FontSize="22"
                                Padding="12"
                                Background="#FAFAFA"
                                BorderBrush="#DDD"
                                BorderThickness="1"/>

                        <!-- Cognome -->
                        <TextBlock Text="Cognome"
                                FontSize="22"
                                Foreground="#666"/>

                        <TextBox x:Name="_txtboxsurname" Height="65"
                                Margin="0,8,0,35"
                                FontSize="22"
                                Padding="12"
                                Background="#FAFAFA"
                                BorderBrush="#DDD"
                                BorderThickness="1"/>

                        <!-- Saldo iniziale -->
                        <TextBlock Text="Saldo iniziale"
                                   FontSize="22"
                                   Foreground="#666"/>

                        <TextBox x:Name="_txtSaldo" Height="65"
                                 Margin="0,8,0,35"
                                 FontSize="22"
                                 Padding="12"
                                 Background="#FAFAFA"
                                 BorderBrush="#DDD"
                                 BorderThickness="1"
                                 Text=""/>

                        <!-- Bottone -->
                        <Button Content="Continua"
                                Height="70"
                                FontSize="24"
                                Background="#2ECC71"
                                Foreground="White"
                                BorderThickness="0" Click="Button_Click"/>

                    </StackPanel>

                </Border>

            </Grid>
        </Grid>

        <Grid x:Name="_pageGrid" d:IsHidden="True">

            <!-- SFONDO -->
            <Canvas>
                <Ellipse Fill="#FF62F5C4" Width="1542" Height="1164" Canvas.Left="-362" Canvas.Top="-184"/>
                <Ellipse Fill="#FF62F5C4" Width="1536" Height="1318" Canvas.Left="720" Canvas.Top="128"/>

                <Ellipse Fill="#FFE4E6E5" Width="1432" Height="1362" Canvas.Left="-332" Canvas.Top="-82"/>
                <Ellipse Fill="#FFE4E6E5" Width="900" Height="900" Canvas.Left="776" Canvas.Top="310"/>

                <Ellipse Fill="#FFF4F7F6" Width="1242" Height="1388" Canvas.Left="-362" Canvas.Top="260"/>
                <Ellipse Fill="#FFF4F7F6" Width="900" Height="900" Canvas.Left="600" Canvas.Top="546"/>

                <!-- Header -->
            </Canvas>

            <!-- HEADER CONTENUTO -->
            <Grid Margin="80,40,80,0" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Sinistra -->
                <StackPanel>

                    <TextBlock Text="Welcome back,"
                       FontSize="50"
                       Foreground="#2ECC71" Height="55"/>

                    <TextBlock x:Name="_txtName"
                       Text="Nome Utente"
                       FontSize="80"
                       FontWeight="Bold"/>
                </StackPanel>

                <!-- Destra -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Saldo"
                       FontSize="30"
                       Foreground="#666"
                       HorizontalAlignment="Right"/>

                    <TextBlock x:Name="_txtboxbalance"
                       Text="€ 0.00"
                       FontSize="60"
                       FontWeight="Bold"
                       HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- CONTENUTO -->
            <StackPanel Margin="80,250,80,80">

                <!-- CARD INFO -->
                <UniformGrid Columns="4" Margin="0,0,0,40">

                    <!-- Card 1 -->
                    <Border Background="White" CornerRadius="20" Margin="10" Padding="20" MinHeight="140">
                        <StackPanel>
                            <TextBlock Text="Spesi questo mese" FontSize="20"/>
                            <TextBlock Text="€ 0.00" FontSize="35" FontWeight="Bold"/>
                            <Button Content="Vedi di più"
                                    Height="40"
                                    Width="140"
                                    HorizontalAlignment="Right"
                                    Margin="0,12,0,0"
                                    Background="#2ECC71"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 2 -->
                    <Border Background="White" CornerRadius="20" Margin="10" Padding="20" MinHeight="140">
                        <StackPanel>
                            <TextBlock Text="Incassi questo mese" FontSize="20"/>
                            <TextBlock Text="€ 0.00" FontSize="35" FontWeight="Bold"/>
                            <Button Content="Vedi di più"
                                    Height="40"
                                    Width="140"
                                    HorizontalAlignment="Right"
                                    Margin="0,12,0,0"
                                    Background="#2ECC71"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 3 -->
                    <Border Background="White" CornerRadius="20" Margin="10" Padding="20" MinHeight="140">
                        <StackPanel>
                            <TextBlock Text="Rinnovi a breve" FontSize="20"/>
                            <TextBlock Text="0" FontSize="35" FontWeight="Bold"/>
                            <Button Content="Vedi di più"
                                    Height="40"
                                    Width="140"
                                    HorizontalAlignment="Right"
                                    Margin="0,12,0,0"
                                    Background="#2ECC71"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 4 -->
                    <Border Background="White" CornerRadius="20" Margin="10" Padding="20" MinHeight="140">
                        <StackPanel>
                            <TextBlock Text="Totale abbonamenti" FontSize="20"/>
                            <TextBlock Text="0" FontSize="35" FontWeight="Bold"/>
                            <Button Content="Vedi di più"
                                    Height="40"
                                    Width="140"
                                    HorizontalAlignment="Right"
                                    Margin="0,12,0,0"
                                    Background="#2ECC71"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- GRAFICO + AZIONI -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- GRAFICO -->
                    <Border Background="White"
                            CornerRadius="20"
                            Margin="10,10,10,10"
                            Padding="20">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Grafico spese"
                                       FontSize="25"
                                       Margin="0,0,0,10"/>

                            <!-- Placeholder: fixed max height so it doesn't overflow -->
                            <Rectangle
                                       Height="230"
                                       Fill="#EEE"
                                       RadiusX="10"
                                       RadiusY="10" VerticalAlignment="Top" Grid.RowSpan="2" Margin="0,33,0,0"/>
                        </Grid>
                    </Border>

                    <!-- AZIONI -->
                    <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="20"
                    Margin="10,10,10,10"
                    Padding="20">

                        <StackPanel>

                            <TextBlock Text="Azioni"
                               FontSize="25"
                               Margin="0,0,0,20"/>

                            <Button Content="Aggiungi abbonamento"
                            Height="60"
                            Margin="0,0,0,15"
                            Background="#2ECC71"
                            Foreground="White"/>

                            <Button Content="Aggiungi entrata"
                            Height="60"
                            Margin="0,0,0,15"
                            Background="#3498DB"
                            Foreground="White"/>
                            <Button Content="Aggiungi spesa"
                            Height="60"
                            Background="#E74C3C"
                            Foreground="White"/>

                        </StackPanel>
                    </Border>

                </Grid>

            </StackPanel>

        </Grid>
    </Grid>
</Window>