<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d"
    x:Class="FinanceTracker.MainWindow"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="MainWindow"
    WindowState="Maximized"
    Background="#F4F7F6">

    <Grid>
        <!-- Background shapes (kept in a Canvas so positioning stays the same) -->
        <Canvas
            Width="{Binding
            RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth}"
            Height="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualHeight}"
            IsHitTestVisible="False" d:IsHidden="True">
            <Ellipse Fill="#FF62F5C4" Width="1542" Height="1164" Canvas.Left="-362"
                Canvas.Top="-184" />
            <Ellipse Fill="#FF62F5C4" Width="1536" Height="1318" Canvas.Left="720" Canvas.Top="128" />

            <Ellipse Fill="#FFE4E6E5" Width="1432" Height="1362" Canvas.Left="-332" Canvas.Top="-82" />
            <Ellipse Fill="#FFE4E6E5" Width="900" Height="900" Canvas.Left="776" Canvas.Top="310" />

            <Ellipse Fill="#FFF4F7F6" Width="1242" Height="1388" Canvas.Left="-362" Canvas.Top="260" />
            <Ellipse Fill="#FFF4F7F6" Width="900" Height="900" Canvas.Left="600" Canvas.Top="546" />
        </Canvas>

        <!-- Overlay content: login and page grids. They stretch and are positioned using alignment
        rather than fixed sizes. -->
        <Grid x:Name="_loginGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- CONTENUTO -->
            <Grid Background="#00000000">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- TESTO -->
                <StackPanel Grid.Column="0" Margin="150,180,50,0" MaxWidth="750">
                    <TextBlock Text="Welcome!"
                        FontSize="140"
                        FontWeight="Bold"
                        Foreground="#2ECC71" />
                    <TextBlock Text="To start please complete the form"
                        FontSize="65"
                        Foreground="#23A95C"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!-- CARD LOGIN -->
                <Border Grid.Column="1" Width="550"
                    Padding="50"
                    Background="White"
                    CornerRadius="25"
                    VerticalAlignment="Center"
                    Margin="0,0,150,0">

                    <!-- Ombra semplice -->
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25"
                            ShadowDepth="5"
                            Opacity="0.2" />
                    </Border.Effect>

                    <StackPanel>

                        <TextBlock Text="Login"
                            FontSize="50"
                            FontWeight="Bold"
                            Margin="0,0,0,40"
                            Foreground="#333" />

                        <!-- Nome -->
                        <TextBlock Text="Nome"
                            FontSize="22"
                            Foreground="#666" />

                        <TextBox x:Name="_txtboxname" Height="65"
                            Margin="0,8,0,25"
                            FontSize="22"
                            Padding="12"
                            Background="#FAFAFA"
                            BorderBrush="#DDD"
                            BorderThickness="1" />

                        <!-- Cognome -->
                        <TextBlock Text="Cognome"
                            FontSize="22"
                            Foreground="#666" />

                        <TextBox x:Name="_txtboxsurname" Height="65"
                            Margin="0,8,0,35"
                            FontSize="22"
                            Padding="12"
                            Background="#FAFAFA"
                            BorderBrush="#DDD"
                            BorderThickness="1" />

                        <!-- Saldo iniziale -->
                        <TextBlock Text="Saldo iniziale"
                            FontSize="22"
                            Foreground="#666" />

                        <TextBox x:Name="_txtSaldo" Height="65"
                            Margin="0,8,0,35"
                            FontSize="22"
                            Padding="12"
                            Background="#FAFAFA"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            Text="" />

                        <!-- Bottone -->
                        <Button Content="Continua"
                            Height="70"
                            FontSize="24"
                            Background="#2ECC71"
                            Foreground="White"
                            BorderThickness="0" Click="Button_Click" />

                    </StackPanel>

                </Border>

            </Grid>
        </Grid>

        <Grid x:Name="_pageGrid">

            <!-- SFONDO -->
            <Canvas>
                <Ellipse Fill="#FF62F5C4" Width="1542" Height="1164" Canvas.Left="-362"
                    Canvas.Top="-184" />
                <Ellipse Fill="#FF62F5C4" Width="1536" Height="1318" Canvas.Left="720"
                    Canvas.Top="128" />

                <Ellipse Fill="#FFE4E6E5" Width="1432" Height="1362" Canvas.Left="-332"
                    Canvas.Top="-82" />
                <Ellipse Fill="#FFE4E6E5" Width="900" Height="900" Canvas.Left="776"
                    Canvas.Top="310" />

                <Ellipse Fill="#FFF4F7F6" Width="1242" Height="1388" Canvas.Left="-362"
                    Canvas.Top="260" />
                <Ellipse Fill="#FFF4F7F6" Width="900" Height="900" Canvas.Left="600"
                    Canvas.Top="546" />

                <!-- Header -->
            </Canvas>

            <!-- HEADER CONTENUTO -->
            <Grid Margin="80,40,80,0" VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Sinistra -->
                <StackPanel>

                    <TextBlock Text="Welcome back,"
                        FontSize="50"
                        Foreground="#2ECC71" Height="55" />

                    <TextBlock x:Name="_txtName"
                        Text="Nome Utente"
                        FontSize="80"
                        FontWeight="Bold" />
                </StackPanel>

                <!-- Destra -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="Saldo"
                        FontSize="30"
                        Foreground="#666"
                        HorizontalAlignment="Right" />

                    <TextBlock x:Name="_txtboxbalance"
                        Text="€ 0.00"
                        FontSize="60"
                        FontWeight="Bold"
                        HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>

            <!-- CONTENUTO -->
            <StackPanel Margin="80,250,80,80">

                <!-- CARD INFO -->
                <UniformGrid Columns="4" Margin="0,0,0,40">

                    <!-- Card 1 -->
                    <Border Background="White" CornerRadius="20" Margin="10" Padding="20"
                        MinHeight="140">
                        <StackPanel>
                            <TextBlock Text="Spesi questo mese" FontSize="20" />
                            <TextBlock x:Name="_txtMonthTransaction" Text="€ 0.00" FontSize="35"
                                FontWeight="Bold" />
                            <Button x:Name="_btnExpences" Content="Vedi di più"
                                Height="40"
                                Width="140"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0"
                                Background="#2ECC71"
                                Foreground="White"
                                BorderThickness="0"
                                Click="BtnSeeMore_Click" />
                        </StackPanel>
                    </Border>

                    <!-- Card 2 -->
                    <Border Background="White" CornerRadius="20" Margin="10" Padding="20"
                        MinHeight="140">
                        <StackPanel>
                            <TextBlock Text="Incassi questo mese" FontSize="20" />
                            <TextBlock x:Name="_txtMonthIncome" Text="€ 0.00" FontSize="35"
                                FontWeight="Bold" />
                            <Button x:Name="_btnIncome" Content="Vedi di più"
                                Height="40"
                                Width="140"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0"
                                Background="#2ECC71"
                                Foreground="White"
                                BorderThickness="0"
                                Click="BtnSeeMore_Click" />
                        </StackPanel>
                    </Border>

                    <!-- Card 3 -->
                    <Border Background="White" CornerRadius="20" Margin="10" Padding="20"
                        MinHeight="140">
                        <StackPanel>
                            <TextBlock Text="Rinnovi a breve" FontSize="20" />
                            <TextBlock x:Name="_txtNearRenwals" Text="0" FontSize="35"
                                FontWeight="Bold" />
                            <Button x:Name="_btnRenewal" Content="Vedi di più"
                                Height="40"
                                Width="140"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0"
                                Background="#2ECC71"
                                Foreground="White"
                                BorderThickness="0"
                                Click="BtnSeeMore_Click" />
                        </StackPanel>
                    </Border>

                    <!-- Card 4 -->
                    <Border Background="White" CornerRadius="20" Margin="10" Padding="20"
                        MinHeight="140">
                        <StackPanel>
                            <TextBlock Text="Totale abbonamenti" FontSize="20" />
                            <TextBlock x:Name="_txtSubsription" Text="0" FontSize="35"
                                FontWeight="Bold" />
                            <Button x:Name="_btnSubscription" Content="Vedi di più"
                                Height="40"
                                Width="140"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0"
                                Background="#2ECC71"
                                Foreground="White"
                                BorderThickness="0"
                                Click="BtnSeeMore_Click" />
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- GRAFICO + AZIONI -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- GRAFICO -->
                    <Border Background="White"
                        CornerRadius="20"
                        Margin="10,10,10,10"
                        Padding="20">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Andamento Mensile" FontSize="25" Margin="0,0,0,10" />

                            <ItemsControl x:Name="_chartContainer" Grid.Row="1" Height="250"
                                VerticalAlignment="Bottom">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Bottom" Margin="20,0">
                                            <Border Height="{Binding Value}" Width="80"
                                                Background="{Binding Color}" CornerRadius="8,8,0,0">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="10" Opacity="0.1"
                                                        ShadowDepth="2" />
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="{Binding Label}"
                                                HorizontalAlignment="Center" Margin="0,5,0,0"
                                                FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding AmountFormatted}"
                                                HorizontalAlignment="Center" FontSize="12"
                                                Foreground="#666" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>
                    </Border>

                    <!-- AZIONI -->
                    <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="20"
                        Margin="10,10,10,10"
                        Padding="20">

                        <StackPanel>

                            <TextBlock Text="Azioni"
                                FontSize="25"
                                Margin="0,0,0,20" />

                            <Button Content="Aggiungi abbonamento"
                                x:Name="_btnaddSubscription"
                                Height="60"
                                Margin="0,0,0,15"
                                Background="#2ECC71"
                                Foreground="White"
                                Click="_btnAdd_Click" />

                            <Button Content="Aggiungi entrata"
                                x:Name="_btnaddTransaction"
                                Height="60"
                                Margin="0,0,0,15"
                                Background="#3498DB"
                                Foreground="White"
                                Click="_btnAdd_Click" />
                            <Button Content="Aggiungi spesa"
                                x:Name="_btnaddSpent"
                                Height="60"
                                Background="#E74C3C"
                                Foreground="White"
                                Click="_btnAdd_Click" />

                        </StackPanel>
                    </Border>

                </Grid>

            </StackPanel>

        </Grid>
        <Grid x:Name="_viewMoreGrid" Visibility="Hidden">

            <Border x:Name="_expensesBox" Background="#7F000000">
                <Grid>
                    <Border Margin="232,114,232,114"
                        Background="White"
                        CornerRadius="20"
                        Padding="20">


                        <Grid>
                            <!-- Bottone chiudi -->
                            <Button x:Name="_btnClose"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,10,10,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Click="_btnClose_Click">

                                <Image Source="/Sprites/close.png"
                                    Width="46"
                                    Height="44" />
                            </Button>

                            <!-- LISTA -->
                            <ScrollViewer Margin="0,60,0,0">
                                <ItemsControl x:Name="_itemsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFFFFF"
                                                CornerRadius="15"
                                                Margin="0,0,0,12"
                                                Padding="15">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- SINISTRA -->
                                                    <StackPanel>

                                                        <!-- NOME -->
                                                        <TextBlock Text="{Binding Name}"
                                                            FontSize="20"
                                                            FontWeight="Bold" />

                                                        <TextBlock Text="{Binding Description}"
                                                            FontSize="16"
                                                            Foreground="#777"
                                                            Margin="0,5,0,0" />


                                                        <TextBlock x:Name="_txtPrice"
                                                            Grid.Column="1"
                                                            Text="{Binding Price, StringFormat=€ {0:F2}}"
                                                            FontSize="18"
                                                            FontWeight="Bold"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>

                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

        </Grid>
        <Grid x:Name="_addGrid" Background="#7F000000" Visibility="Hidden">
            <Border Margin="232,114,232,114"
                Background="White"
                CornerRadius="20"
                Padding="20">

                <Grid>
                    <Grid x:Name="_addSubscription" Visibility="Collapsed">
                        <StackPanel Margin="30">
                            <TextBlock Text="Aggiungi abbonamento"
                                FontSize="28"
                                FontWeight="Bold"
                                Foreground="#333333"
                                Margin="0,0,0,20" />

                            <TextBlock Text="Nome" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddSubName"
                                Height="40"
                                Margin="0,6,0,12"
                                FontSize="16"
                                VerticalContentAlignment="Center"
                                Padding="8,0" />

                            <TextBlock Text="Descrizione" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddSubDescription"
                                Height="40"
                                Margin="0,6,0,12"
                                FontSize="16"
                                VerticalContentAlignment="Center"
                                Padding="8,0" />

                            <TextBlock Text="Costo" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddSubCost"
                                Height="40"
                                Margin="0,6,0,12"
                                FontSize="16"
                                VerticalContentAlignment="Center"
                                Padding="8,0"
                                ToolTip="Inserisci l'importo (es. 9,99)" />

                            <TextBlock Text="Data primo rinnovo" FontSize="16" Foreground="#666666" />
                            <DatePicker x:Name="_dateAddSub"
                                Height="40"
                                Margin="0,6,0,25"
                                VerticalContentAlignment="Center"
                                SelectedDate="{x:Static sys:DateTime.Today}" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Annulla"
                                    Height="44"
                                    Width="120"
                                    Margin="0,0,10,0"
                                    Background="#E0E0E0"
                                    BorderThickness="0"
                                    Click="_btnCloseIncome_Click" />

                                <Button x:Name="_btnSaveSubscription"
                                    Content="Salva"
                                    Height="44"
                                    Width="120"
                                    Background="#2ECC71"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Click="_btnSaveSubscription_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8" />
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Grid x:Name="_addIncome" Visibility="Collapsed">
                        <StackPanel Margin="30">
                            <TextBlock Text="Aggiungi entrata" FontSize="28" FontWeight="Bold"
                                Foreground="#333333" Margin="0,0,0,20" />

                            <TextBlock Text="Nome" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddIncomeName" Height="40" Margin="0,6,0,12"
                                FontSize="16" VerticalContentAlignment="Center" Padding="8,0" />

                            <TextBlock Text="Descrizione" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddIncomeDescription" Height="40" Margin="0,6,0,12"
                                FontSize="16" VerticalContentAlignment="Center" Padding="8,0" />

                            <TextBlock Text="Importo" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddIncomeCost" Height="40" Margin="0,6,0,12"
                                FontSize="16" VerticalContentAlignment="Center" Padding="8,0" />

                            <TextBlock Text="Data" FontSize="16" Foreground="#666666" />
                            <DatePicker x:Name="_dateAddIncome" Height="40" Margin="0,6,0,25"
                                VerticalContentAlignment="Center"
                                SelectedDate="{x:Static sys:DateTime.Today}" />

                            <CheckBox x:Name="_chkIncomeRecurring"
                                Content="Stipendio ricorrente (mensile)" Margin="0,0,0,12" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Annulla" Height="44" Width="120" Margin="0,0,10,0"
                                    Background="#E0E0E0" BorderThickness="0"
                                    Click="_btnCloseIncome_Click" />
                                <Button x:Name="_btnSaveIncome" Content="Salva" Height="44"
                                    Width="120" Background="#3498DB" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0"
                                    Click="_btnSaveIncome_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Grid x:Name="_addExpense" Visibility="Collapsed">
                        <StackPanel Margin="30">
                            <TextBlock Text="Aggiungi spesa" FontSize="28" FontWeight="Bold"
                                Foreground="#333333" Margin="0,0,0,20" />

                            <TextBlock Text="Nome" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddExpenseName" Height="40" Margin="0,6,0,12"
                                FontSize="16" VerticalContentAlignment="Center" Padding="8,0" />

                            <TextBlock Text="Descrizione" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddExpenseDescription" Height="40"
                                Margin="0,6,0,12" FontSize="16" VerticalContentAlignment="Center"
                                Padding="8,0" />

                            <TextBlock Text="Importo" FontSize="16" Foreground="#666666" />
                            <TextBox x:Name="_txtAddExpenseCost" Height="40" Margin="0,6,0,12"
                                FontSize="16" VerticalContentAlignment="Center" Padding="8,0" />

                            <TextBlock Text="Data" FontSize="16" Foreground="#666666" />
                            <DatePicker x:Name="_dateAddExpense" Height="40" Margin="0,6,0,25"
                                VerticalContentAlignment="Center"
                                SelectedDate="{x:Static sys:DateTime.Today}" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Annulla" Height="44" Width="120" Margin="0,0,10,0"
                                    Background="#E0E0E0" BorderThickness="0"
                                    Click="_btnCloseIncome_Click" />
                                <Button x:Name="_btnSaveExpense" Content="Salva" Height="44"
                                    Width="120" Background="#E74C3C" Foreground="White"
                                    FontWeight="Bold" BorderThickness="0"
                                    Click="_btnSaveExpense_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Button x:Name="_btnCloseAdd"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Cursor="Hand"
                        Click="_btnCloseIncome_Click">
                        <Image Source="/Sprites/close.png"
                            Width="46"
                            Height="44" />
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>